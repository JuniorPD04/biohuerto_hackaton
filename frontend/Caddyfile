{$APP_DOMAIN:localhost} {
  encode zstd gzip

  @backend path /api/* /auth/* /health
  reverse_proxy @backend backend:8000

  @serviceworker path /sw.js /manifest.webmanifest
  header @serviceworker Cache-Control "no-cache, no-store, must-revalidate"

  @assets path /assets/* /pwa/*
  header @assets Cache-Control "public, max-age=31536000, immutable"

  root * /srv
  try_files {path} /index.html
  file_server

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "camera=(self), geolocation=(self), notifications=(self)"
  }
}
