DATABASE_URL=postgresql+asyncpg://app_bio_user:change-me-app-password@127.0.0.1:5432/biohuerto
APP_NAME=Biohuerto Inteligente
ENVIRONMENT=development
SECRET_KEY=change-me-use-at-least-32-random-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# OpenAI: solo para embeddings del RAG (text-embedding-3-small, 1536 dim).
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# OpenRouter: vision (reconocimiento/diagnostico de plantas) y texto (recomendaciones).
OPENROUTER_API_KEY=
OPENROUTER_MODEL_VISION=google/gemini-3-flash-preview
OPENROUTER_MODEL_TEXT=google/gemini-2.5-flash

FERNET_KEY=
