POSTGRES_DB=biohuerto
POSTGRES_SUPERUSER_PASSWORD=change-me-superuser-password
MIGRATION_DB_PASSWORD=change-me-migration-password
APP_DB_PASSWORD=change-me-app-password

# Para ejecutar con run.py en tu maquina local.
# Docker Compose sobreescribe esta variable con host "db" dentro del contenedor backend.
DATABASE_URL=postgresql+asyncpg://app_bio_user:change-me-app-password@127.0.0.1:5432/biohuerto
APP_NAME=Biohuerto Inteligente
ENVIRONMENT=development
SECRET_KEY=change-me-use-at-least-32-random-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

OPENAI_API_KEY=
OPENAI_MODEL_TEXT=
OPENAI_MODEL_VISION=
FERNET_KEY=

PGCRYPTO_KEY=bkey
